# ===========================================================================
# flatwatch configuration. Copy to `.env` and fill in. No secrets in git.
# ===========================================================================

# --- Sources (at least one of KA_SEARCH_URLS / RSS_URLS is required) --------
# Comma- or newline-separated Kleinanzeigen search-result URLs.
KA_SEARCH_URLS=https://www.kleinanzeigen.de/s-wohnung-mieten/berlin/c203l3331
# Comma- or newline-separated RSS/Atom feed URLs (the durable backbone).
RSS_URLS=

# --- Filter criteria (any left blank is simply not applied) ----------------
# A listing whose attribute can't be parsed (None) is NEVER disqualified.
MIN_RENT=
MAX_RENT=1400
MIN_ROOMS=2
MAX_ROOMS=
MIN_SQM=50
MAX_SQM=
# Comma-separated, case-insensitive. All required keywords must be present;
# any excluded keyword rejects the listing.
REQUIRED_KEYWORDS=
EXCLUDED_KEYWORDS=Tausch,WBS,Untermiete

# --- Polling / politeness --------------------------------------------------
POLL_INTERVAL_MIN=30          # floor is 30; lower values are clamped up
PER_REQUEST_DELAY_S=2.0       # base delay between source requests
REQUEST_JITTER_S=1.5          # random jitter added to the delay
HTTP_TIMEOUT_S=20
HTTP_MAX_RETRIES=3            # retries on 5xx/timeout (2s,4s,8s backoff); 403 not retried
KA_MAX_PAGES=20              # walk Kleinanzeigen result pages (seite:2,3,…) up to this many;
                             # stops early at the first empty/repeated page. 1 = first page only.
# Umkreissuche: default search radius in km around each Kleinanzeigen location
# (appends an "r<km>" suffix, e.g. .../erfurt/c203l3741 -> .../erfurt/c203l3741r50),
# so a town search also surfaces flats in the surrounding area. Blank = no radius.
# Per-search rows in the NocoDB searches table can override this via a radius_km cell.
KA_DEFAULT_RADIUS_KM=
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64; rv:124.0) Gecko/20100101 Firefox/124.0
# When true, every new KA listing has its detail page fetched once (spaced by
# PER_REQUEST_DELAY_S) to capture the FULL description and all detail fields
# (bedrooms, bathrooms, floor, type, Verfügbar ab, Nebenkosten, Warmmiete,
# Kaution, feature tags) plus any missing price/rooms/sqm. Recommended for the
# results table. Default false = no detail fetches (only search-card data).
ENRICH_DETAIL=false
# A large first run with ENRICH_DETAIL is enriched + stored in batches of this size,
# so rows land in NocoDB progressively (and survive a restart) instead of only at the end.
PERSIST_BATCH_SIZE=25

# Daily recheck: re-fetch still-available listings in the results table and flag
# removed ones (404 / "nicht mehr verfügbar") as available=false + removed_at.
RECHECK_ENABLED=true
RECHECK_INTERVAL_DAYS=1

# --- Dedup store: NocoDB primary, JSON fallback ----------------------------
JSON_STORE_PATH=/data/seen.json
NOCODB_URL=                   # e.g. https://nocodb.mynas.local
NOCODB_TOKEN=                 # xc-token API token
NOCODB_TABLE_ID=              # table id of the "seen listings" table
NOCODB_ID_FIELD=listing_id    # column holding the stable dedup key

# --- Dynamic searches (optional): edit searches live in NocoDB --------------
# When set, searches (URL + per-search criteria) are read from this table at the
# start of every cycle, so edits take effect on the next poll with no redeploy.
# Blank criteria cells inherit the global criteria above. If the table is
# unreachable or empty, flatwatch falls back to KA_SEARCH_URLS/RSS_URLS + the
# global criteria. Leave unset to use the static env vars only.
NOCODB_SEARCHES_TABLE_ID=

# --- Results table (optional): full row per matching listing ----------------
# When set, every newly-matched listing is written to this NocoDB table with its
# full details (price, rooms, sqm, location, description, first_seen) — so you can
# browse everything in NocoDB even with notifications off. A fresh deploy captures
# the whole current backlog on the first cycle. Set ENRICH_DETAIL=true for the most
# complete price/rooms/sqm. Leave unset to skip.
NOCODB_LISTINGS_TABLE_ID=

# --- Notifications (each channel is independent; partial config disables it)-
# Leave ALL of these blank to disable notifications entirely (matches are still
# logged and, if configured, written to NocoDB).
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
SMTP_USE_TLS=true
HA_WEBHOOK_URL=               # optional Home Assistant webhook (C3)
MAX_NOTIFY_PER_CYCLE=15       # over this, send N individually + one summary (C2)

# --- Health / heartbeat (A3) -----------------------------------------------
HEALTH_PATH=/data/health.json
HEALTHCHECK_PORT=8080         # GET /health -> 200 healthy / 503 failing; unset disables the server
HEALTH_STALE_AFTER_MIN=0      # /health returns 503 if no cycle completes within this many
                              # minutes; 0 = auto (2× POLL_INTERVAL_MIN)
FAILURE_ALERT_THRESHOLD=3     # after this many consecutive failed cycles, /health is 503 and
                              # one alert is sent
ALERT_ON_REPEATED_FAILURES=true   # send a Telegram/email alert on sustained outage + recovery

# --- MCP endpoint (let Claude trigger a run on demand) ---------------------
# When true, the container serves a FastMCP endpoint (streamable-HTTP) with the
# tools trigger_run, get_status, and list_searches. Add it to Claude as a custom
# connector: http://<nas-ip>:<MCP_PORT>/mcp
MCP_ENABLED=false
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_PATH=/mcp
MCP_AUTH_TOKEN=               # optional: if set, require Authorization: Bearer <token>

# --- Run-logging to NocoDB (Epic E) ----------------------------------------
RUN_LOG_ENABLED=true
NOCODB_RUNS_TABLE_ID=         # table id for flatwatch_runs
NOCODB_RUN_EVENTS_TABLE_ID=   # table id for flatwatch_run_events
RUN_LOG_RETENTION_DAYS=30     # 0 disables pruning
RUN_LOG_JSONL_PATH=/data/runs.jsonl   # offline buffer, replayed when NocoDB returns

# --- Misc ------------------------------------------------------------------
APP_VERSION=dev               # surfaced in run records (set to git sha / image tag)
# Trigger an immediate on-demand cycle (recorded as trigger=manual) by sending
# SIGUSR1 to the container:  docker kill -s USR1 flatwatch
